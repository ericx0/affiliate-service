{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["src/**/*.ts", "src/db/migrations/**/*.sql"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "crons": [
    {
      "path": "/api/affiliate/cron/approve-cooldown",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/affiliate/cron/monthly-payout",
      "schedule": "0 23 14 * *"
    }
  ]
}
